  "검정포맥스_2T_120x240":  {w:120, h:240, price:19000,  type:"black"},
  "검정포맥스_3T_90x180":   {w:90,  h:180, price:19000,  type:"black"},
  "검정포맥스_3T_120x240":  {w:120, h:240, price:26000,  type:"black"},
  "검정포맥스_5T_90x180":   {w:90,  h:180, price:24000,  type:"black"},
  "검정포맥스_5T_120x240":  {w:120, h:240, price:40000,  type:"black"},
  "검정포맥스_8T_90x180":   {w:90,  h:180, price:41000,  type:"black"},
  "검정포맥스_8T_120x240":  {w:120, h:240, price:71000,  type:"black"},
  "검정포맥스_10T_90x180":  {w:90,  h:180, price:52000,  type:"black"},
