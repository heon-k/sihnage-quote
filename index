  // ── 아크릴 ──
  "아크릴_5T_90x180":       {w:90,  h:180, price:60000,  type:"acrylic"},
  "아크릴_5T_122x244":      {w:122, h:244, price:100000, type:"acrylic"},
  "아크릴_8T_90x180":       {w:90,  h:180, price:96000,  type:"acrylic_thick"},
  "아크릴_8T_120x240":      {w:120, h:240, price:170000, type:"acrylic_thick"},
  "아크릴_10T_90x180":      {w:90,  h:180, price:115000, type:"acrylic_thick"},
  "아크릴_10T_120x240":     {w:120, h:240, price:210000, type:"acrylic_thick"},
  // ── 알마이트 ──
  "알마이트_2T_122x244":    {w:122, h:244, price:26000,  type:"alumite"}
};

const SIGN_TYPES  = ["조명용 간판","비조명 간판","15각 파이프","19각 파이프"];
const CUT_MULT    = 1.5;
const CNC_MULT    = 2.5;
const PRINT_SQM   = 18000;
const MIN_PRINT   = 10000;
  const MIN_LASER   = 15000;   // 레이저 최소 가공비 (잠정)
const PIPE_FACTOR = 1.2;

function calcYield(bw, bh, tw, th) {
  if (tw > bw && tw > bh) return 0;
  if (th > bw && th > bh) return 0;
  return Math.max(
    Math.floor(bw/tw) * Math.floor(bh/th),
    Math.floor(bw/th) * Math.floor(bh/tw)
  );
}

function calcBoard(matKey, tw, th, proc, printed) {
  const b = MATERIALS[matKey];
  if (!b) return {error:"등록되지 않은 자재"};
  let pieces, unitMat, procType = proc;

  if ((tw==b.w&&th==b.h)||(tw==b.h&&th==b.w)) {
    pieces=1; unitMat=b.price; procType="없음";
  } else {
    pieces = calcYield(b.w, b.h, tw, th);
    if (!pieces) return {error:"원판보다 큰 사이즈입니다"};
    unitMat = b.price / pieces;
  }

  let procCost;
  if      (proc==="재단")           procCost = unitMat * CUT_MULT;
  else if (proc==="레이저"||proc==="cnc") procCost = Math.max(MIN_LASER, unitMat * CNC_MULT);
  else                               procCost = unitMat;

  let printCost = 0;
  if (printed) {
    let p = (tw/100)*(th/100)*PRINT_SQM;
    if (b.type==="black") p *= 1.5;
    printCost = Math.max(MIN_PRINT, p);
  }

  const total = Math.round((procCost + printCost)/100)*100;
  return {pieces, unitMat, procCost, printCost, total, procType};
}

function calcSign(pType, wMm, hMm, qty) {
  const w = wMm/1000, h=(hMm||0)/1000;
  qty = qty||1;
  switch(pType) {
    case "조명용 간판": return Math.round((w+h)*2*11200*PIPE_FACTOR) * qty;
    case "비조명 간판": return Math.round((w+h)*2*6800 *PIPE_FACTOR) * qty;
    case "15각 파이프": return Math.round(w*1000*PIPE_FACTOR) * qty;
    case "19각 파이프": return Math.round(w*1100*PIPE_FACTOR) * qty;
  }
  return null;
}

// ════════════════════════════════════════════
//  UI 이벤트
// ════════════════════════════════════════════
let quoteItems = [];

function onMaterialChange() {
  const mat  = document.getElementById("material").value;
  const isSign = SIGN_TYPES.includes(mat);
  const isPipe = mat.includes("파이프");

  document.getElementById("unitHint").classList.toggle("show", isSign);
  document.getElementById("procField").style.opacity  = isSign ? "0.3" : "1";
  document.getElementById("procField").style.pointerEvents = isSign ? "none" : "auto";
  document.getElementById("printField").style.opacity = isSign ? "0.3" : "1";
  document.getElementById("printField").style.pointerEvents = isSign ? "none" : "auto";

  const wLbl = document.getElementById("wLabel");
  const hLbl = document.getElementById("hLabel");
  const hInput = document.getElementById("height");

  if (isSign) {
    wLbl.textContent = isPipe ? "길이 (mm)" : "가로 (mm)";
    hLbl.textContent = "세로 (mm)";
    if (isPipe) { hInput.placeholder = "파이프는 비워두기"; hInput.value = ""; }
  } else {
    wLbl.textContent = "가로 (cm)";
    hLbl.textContent = "세로 (cm)";
    hInput.placeholder = "예: 60";
  }

  document.getElementById("resultBox").classList.remove("show");
}

function calculate() {
  const mat     = document.getElementById("material").value;
  const w       = parseFloat(document.getElementById("width").value);
  const h       = parseFloat(document.getElementById("height").value) || 0;
  const proc    = document.getElementById("procType").value;
  const printed = document.getElementById("isPrinted").checked;
  const qty     = parseInt(document.getElementById("qty").value) || 1;

  if (!w) { alert("가로(길이)를 입력해주세요."); return; }

  let lines = [], total = 0, label = "";

  if (SIGN_TYPES.includes(mat)) {
    const unitP = calcSign(mat, w, h, 1);
    if (!unitP) { alert("계산 오류: 제품명을 확인해주세요."); return; }
    total = unitP * qty;
    lines = [
      {k:"제품 종류", v: mat},
      {k:"입력 치수", v: `${w}${h?` × ${h}`:""} mm`},
      {k:"수량",      v: `${qty}개`},
      {k:"단위 단가", v: fmt(unitP) + "원"},
    ];
    label = `${fmt(total)}원`;
  } else {
    const r = calcBoard(mat, w, h, proc, printed);
    if (r.error) { alert(r.error); return; }
    const pieces = r.pieces;
    lines = [
      {k:"원판 수율",      v: `1장 → ${pieces}개`},
      {k:"개당 자재 원가", v: fmt(Math.round(r.unitMat)) + "원"},
      {k:"가공비(자재포함)",v: fmt(Math.round(r.procCost)) + `원  [${r.procType}]` + (r.procType==="레이저"&&r.procCost===MIN_LASER?" ★최소가공비":"") },
      {k:"평판 인쇄비",    v: fmt(r.printCost) + "원" + (printed && r.printCost===MIN_PRINT ? "  (최소금액)" : "")},
    ];
    total = r.total * qty;
    label = qty > 1
      ? `${fmt(r.total)}원 × ${qty}개 = ${fmt(total)}원`
      : `${fmt(r.total)}원`;
  }

  // 결과 렌더
  const linesHtml = lines.map(l=>
    `<div class="result-line"><span class="result-key">${l.k}</span><span class="result-val">${l.v}</span></div>`
  ).join("");
  document.getElementById("resultLines").innerHTML = linesHtml;
  document.getElementById("resultAmount").textContent = fmt(total) + "원";
  document.getElementById("resultVatNote").textContent = `수량 ${qty}개 기준 · VAT 별도`;
  document.getElementById("resultBox").classList.add("show");

  // 임시 저장 (추가 버튼용)
  window._lastCalc = {mat, w, h, proc, printed, qty, unitPrice: Math.round(total/qty), totalPrice: total};
}

function addToList() {
  if (!window._lastCalc) return;
  const c = window._lastCalc;
  const isSign = SIGN_TYPES.includes(c.mat);
  const sizeStr = isSign
    ? (c.h ? `${c.w}×${c.h}mm` : `${c.w}mm`)
    : `${c.w}×${c.h}cm`;

  quoteItems.push({
    mat:   c.mat,
    size:  sizeStr,
    proc:  isSign ? "-" : c.proc,
    printed: c.printed,
    qty:   c.qty,
    unitP: c.unitPrice,
    totalP: c.totalPrice
  });

  renderTable();
  document.getElementById("resultBox").classList.remove("show");
  window._lastCalc = null;
}

function removeItem(idx) {
  quoteItems.splice(idx, 1);
  renderTable();
}

function renderTable() {
  const tbody = document.getElementById("quoteBody");
  document.getElementById("itemCount").textContent = `품목 ${quoteItems.length}개`;

  if (!quoteItems.length) {
    tbody.innerHTML = '<tr class="empty-row"><td colspan="6">품목을 추가해주세요</td></tr>';
    document.getElementById("summaryBox").style.display = "none";
    document.getElementById("actionRow").style.display  = "none";
    return;
  }

  let html = "";
  quoteItems.forEach((item, i) => {
    const procTag = item.proc === "재단"
      ? `<span class="tag tag-cut">재단</span>`
      : item.proc === "레이저" || item.proc === "cnc"
        ? `<span class="tag tag-cnc">레이저</span>`
        : `<span class="tag tag-none">-</span>`;
    const printTag = item.printed
      ? `<span class="tag tag-print">인쇄</span>` : "";

    html += `<tr>
      <td style="max-width:140px;word-break:break-all;font-size:12px;">${item.mat}</td>
      <td style="font-family:var(--mono);font-size:12px;">${item.size}</td>
      <td>${procTag}${printTag}</td>
      <td style="font-family:var(--mono);">${item.qty}</td>
      <td class="price-cell">${fmt(item.totalP)}</td>
      <td><button class="del-btn" onclick="removeItem(${i})">×</button></td>
    </tr>`;
  });
  tbody.innerHTML = html;

  // 합계
  const subtotal = quoteItems.reduce((s,it) => s + it.totalP, 0);
  const vat      = Math.round(subtotal * 0.1 / 100) * 100;
  const total    = subtotal + vat;

  document.getElementById("subtotalEl").textContent = fmt(subtotal) + "원";
  document.getElementById("vatEl").textContent      = fmt(vat)      + "원";
  document.getElementById("totalEl").textContent    = fmt(total)    + "원";
  document.getElementById("summaryBox").style.display = "block";
  document.getElementById("actionRow").style.display  = "grid";
}

function clearAll() {
  if (!confirm("견적 목록을 모두 초기화할까요?")) return;
  quoteItems = [];
  renderTable();
}

function printQuote() {
  const client = document.getElementById("clientName").value || "고 객 사";
  const today  = new Date().toLocaleDateString("ko-KR", {year:"numeric",month:"long",day:"numeric"});
  document.getElementById("printMeta").textContent = `수신: ${client}  |  견적일: ${today}  |  VAT 별도`;
  window.print();
}

function fmt(n) {
  return Math.round(n).toLocaleString("ko-KR");
}

// 초기화
onMaterialChange();
</script>
